{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core + engine sidecar + notifications + auto-update for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/intraday-engine", "sidecar": true }]
    },
    "shell:allow-kill"
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "intraday-x",
  "version": "0.0.1",
  "identifier": "com.intradayx.desktop",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && cd frontend && pnpm dev",
    "beforeBuildCommand": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && cd frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "intraday-x",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/billyribeiro-ux/intraday-x/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5ODE0QTc2QzBCNkMwODgKUldTSXdMYkFka3FCR1lkdVhUNVZUNi9iOEl0MVB3SHc4VnJTbTdybjF2QmxxWkJ3anVTVEMzMGYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": { "binaries/engine": "engine" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
